{
  "name": "gruda-armada",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:strict": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "check:assets": "node scripts/verify-assets.mjs",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "prepare": "husky",
    "validate": "tsc --noEmit && eslint src/ && vitest run && vite build",
    "r2:preview": "node scripts/upload-assets-r2.mjs --dry-run",
    "r2:upload": "node scripts/upload-assets-r2.mjs",
    "r2:upload:force": "node scripts/upload-assets-r2.mjs --force",
    "glb:dry": "node scripts/convert-to-glb.mjs --dry-run",
    "glb:convert": "node scripts/convert-to-glb.mjs --skip-draco",
    "glb:convert:full": "node scripts/convert-to-glb.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tweenjs/tween.js": "^25.0.0",
    "camera-controls": "^3.1.0",
    "framer-motion": "^12.38.0",
    "howler": "^2.2.4",
    "immer": "^11.1.4",
    "lil-gui": "^0.21.0",
    "pathfinding": "^0.4.18",
    "postprocessing": "^6.39.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stats-gl": "^4.1.0",
    "three": "^0.183.2",
    "three-mesh-bvh": "^0.9.9",
    "three.quarks": "^0.17.0",
    "troika-three-text": "^0.52.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@eslint/js": "^9.39.4",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@heyputer/puter.js": "^2.2.14",
    "@types/howler": "^2.2.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.7.0",
    "draco3dgltf": "^1.5.7",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "obj2gltf": "^3.2.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  }
}
