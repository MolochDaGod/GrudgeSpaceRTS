# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/grudge_space

# ── JWT ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_string

# ── OAuth Providers ───────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── App ───────────────────────────────────────────────────────────
PORT=3001
APP_URL=https://starrts.grudge-studio.com
CORS_ORIGINS=https://starrts.grudge-studio.com,http://localhost:4541

# ── Object Storage (Cloudflare R2 / AWS S3) ────────────────────────
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=grudge-space-assets
R2_PUBLIC_URL=https://assets.grudge-studio.com

# ── AI Narration ──────────────────────────────────────────────────
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# ── Admin ─────────────────────────────────────────────────────────
# Comma-separated list of grudgeIds that have admin access
ADMIN_GRUDGE_IDS=
