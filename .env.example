# ── Grudge Backend Integration ───────────────────────────────
# Game API — ship data, balance, matches, hero ships
VITE_GRUDGE_API=https://api.grudge-studio.com

# Grudge ID — authentication (Discord, Google, GitHub, Web3Auth)
VITE_GRUDGE_ID_URL=https://id.grudge-studio.com

# Account API — profiles, friends, achievements
VITE_ACCOUNT_API=https://account.grudge-studio.com

# R2 CDN — large 3D model assets (FBX/GLB/OBJ)
VITE_ASSET_CDN=https://grudge-rts.grudge-studio.com

# Cloudflare R2 — asset upload script only (never exposed to frontend)
CF_ACCOUNT_ID=ee475864561b02d4588180b8b9acf694
CF_R2_TOKEN={{CF_R2_TOKEN}}

# WebSocket — real-time multiplayer (future)
VITE_WS_URL=https://ws.grudge-studio.com

# ============================================
# EXTERNAL SERVICES (replace with your own keys)
# ============================================
TWILIO_SID_API={{TWILIO_SID}}
TWILIO_ACCOUNT_API={{TWILIO_AUTH_TOKEN}}
TWILIO_PHONE_NUMBER={{TWILIO_PHONE}}
CROSSMINT_WEBHOOK_API={{CROSSMINT_WEBHOOK_SECRET}}
GOOGLE_CLIENT_ID={{GOOGLE_CLIENT_ID}}
GOOGLE_SECRET_API={{GOOGLE_CLIENT_SECRET}}
GITHUB_CLIENT_ID={{GITHUB_CLIENT_ID}}
GITHUB_CLIENT_SECRET={{GITHUB_CLIENT_SECRET}}
GEMINI_API_KEY={{GEMINI_API_KEY}}
CORS_ORGINS=grudge-studio.com
FRONTEND_URL=https://grudgewarlords.com
Discord_redirect_URL=https://api.grudge-studio.com/auth/discord/callback

# ============================================
# DATABASE - PRIMARY (NEON POSTGRESQL)
# ============================================
DATABASE_URL={{DATABASE_URL}}
DATABASE_URL_UNPOOLED={{DATABASE_URL_UNPOOLED}}

# ============================================
# DATABASE - SECONDARY (SUPABASE)
# ============================================
SUPABASE_URL={{SUPABASE_URL}}
SUPABASE_ANON_KEY={{SUPABASE_ANON_KEY}}
SUPABASE_SERVICE_ROLE_KEY={{SUPABASE_SERVICE_ROLE_KEY}}
SUPABASE_JWT_SECRET={{SUPABASE_JWT_SECRET}}
SUPABASE_DB_URL={{SUPABASE_DB_URL}}

# Frontend-accessible (VITE_ prefix)
VITE_SUPABASE_URL={{SUPABASE_URL}}
VITE_SUPABASE_ANON_KEY={{SUPABASE_ANON_KEY}}

# ============================================
# SESSION & ENCRYPTION
# ============================================
SESSION_SECRET={{SESSION_SECRET}}
JWT_SECRET={{JWT_SECRET}}
TOKEN_ENCRYPTION_KEY={{TOKEN_ENCRYPTION_KEY}}

# ============================================
# AI SERVICES
# ============================================
OPENAI_API_KEY={{OPENAI_API_KEY}}
ANTHROPIC_API_KEY={{ANTHROPIC_API_KEY}}
XAI_API_KEY={{XAI_API_KEY}}
DEEPSEEK_API_KEY={{DEEPSEEK_API_KEY}}
PERPLEXITY_API_KEY={{PERPLEXITY_API_KEY}}
MESHY_API_KEY={{MESHY_API_KEY}}
HUGGINGFACE_API_KEY={{HUGGINGFACE_API_KEY}}
API_TRIPO={{TRIPO_API_KEY}}

# ============================================
# CROSSMINT (NFT & WALLETS)
# ============================================
CROSSMINT_SERVER_API_KEY={{CROSSMINT_SERVER_KEY}}
CROSSMINT_PROJECT_ID={{CROSSMINT_PROJECT_ID}}
VITE_CROSSMINT_CLIENT_KEY={{CROSSMINT_CLIENT_KEY}}
VITE_CROSSMINT_PROJECT_ID={{CROSSMINT_PROJECT_ID}}
VITE_CROSSMINT_CHARACTER_COLLECTION={{CROSSMINT_CHAR_COLLECTION}}
VITE_CROSSMINT_ISLAND_COLLECTION={{CROSSMINT_ISLAND_COLLECTION}}
VITE_CROSSMINT_ENV=production

# ============================================
# Discord
# ============================================
Discord_Public_Key={{DISCORD_PUBLIC_KEY}}
Discord_application_ID={{DISCORD_APP_ID}}
DISCORD_CLIENT_SECRET={{DISCORD_CLIENT_SECRET}}
